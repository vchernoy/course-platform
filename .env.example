# Clerk (required for auth). Copy to `.env.local` and fill real values from the Clerk dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: explicit URLs (defaults usually work with `/sign-in` and `/sign-up` routes)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
