# Clerk (required for auth). Copy to `.env.local` and fill real values from the Clerk dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: explicit URLs (defaults usually work with `/sign-in` and `/sign-up` routes)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Set to false to hide the "Sign up" link on the home page (e.g. when sign-ups are disabled in Clerk).
# NEXT_PUBLIC_SHOW_SIGN_UP_LINK=false

# Cloudflare Stream iframe host (optional). Example: customer-xxxxxxxxxxxx.cloudflarestream.com
# If unset, VideoPlayer uses https://iframe.videodelivery.net/<playbackId>
# NEXT_PUBLIC_CLOUDFLARE_STREAM_CUSTOMER=customer-xxxxxxxxxxxx.cloudflarestream.com

# Optional demo playback ID for the sample lesson mapping `risk-return-overview` → Cloudflare in ProtectedVideo.
# Or pass playbackId directly on <VideoPlayer provider="cloudflare" playbackId="..." /> in MDX.
# NEXT_PUBLIC_CLOUDFLARE_DEMO_PLAYBACK_ID=
